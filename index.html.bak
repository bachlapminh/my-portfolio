            │         class="project-banner" alt="Silkroad Mobile">  │
            └─────────────────────────────────────────────────────────┘
          -->
          <div class="ph project-banner">
            <div class="ph-icon">🎮</div>
            <div class="ph-title">Project Banner — Silkroad Mobile</div>
            <div class="ph-hint">Official Key Art hoặc gameplay screenshot<br>16:9, min 1200×675px</div>
          </div>
          <div class="project-body">
            <div class="project-meta">
              <span class="project-tag">Company Project</span>
              <span class="project-tag">2025</span>
              <span class="project-tag tag-role">Product Owner & Game Design Lead</span>
            </div>
            <h3 class="project-title">Silkroad Online<br>Origin Mobile</h3>
            <p class="project-impact">"Recreated a beloved PC MMORPG for mobile. Won Game of the Year."</p>
            <p class="project-desc">
              A challenge that few would take on: faithfully recreating a beloved 2005 PC MMORPG for modern mobile audiences.
              As Game Design Lead and Product Owner, I reverse-engineered the original game's combat formula,
              rebuilt every core system from scratch, and led the design team through 17 months of development.
            </p>
            <div class="project-stats">
              <div class="project-stat">
                <span class="stat-badge">🏆</span>
                <span>Game of the Year</span>
              </div>
              <div class="project-stat">
